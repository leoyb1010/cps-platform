DATABASE_URL="file:./dev.db"
DATABASE_PROVIDER="sqlite"
JWT_ACCESS_SECRET="CHANGE_ME"
JWT_REFRESH_SECRET="CHANGE_ME"
ACCESS_TTL="900s"
REFRESH_TTL_DAYS="14"
PORT="3001"
CORS_ORIGIN="http://localhost:5273"
NODE_ENV="development"

# ── 生产（NODE_ENV=production）必读 ────────────────────────────────
# 有道出站回调平台私钥（PEM）。生产必填：未设或含仓库内公开 demo 私钥 → 启动即拒（main.ts assertSecrets）。
# 生成：openssl genrsa 2048  然后把整段 PEM（含 BEGIN/END PRIVATE KEY 行）填入。
# 开发/测试留空即回退 demo 私钥，仅供本地联调，切勿用于生产。
# YOUDAO_PLATFORM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 是否灌演示种子数据。生产默认只 bootstrap 首个管理员、不灌 demo；预发/沙箱需要演示数据时显式设 true。
# SEED_DEMO="false"

# 是否暴露 Swagger 文档 /docs。生产默认关闭；仅内网预发等场景显式放行。
# EXPOSE_SWAGGER="false"
