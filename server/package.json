{
  "name": "cps-platform-server",
  "version": "1.0.0",
  "private": true,
  "description": "网易有道 CPS 平台 — 后端 (NestJS + Prisma + SQLite)",
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push --skip-generate",
    "seed": "ts-node prisma/seed.ts",
    "bootstrap:admin": "ts-node prisma/bootstrap-admin.ts",
    "db:reset": "prisma migrate reset --force",
    "generate:pg": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:push:pg": "prisma db push --schema prisma/schema.postgres.prisma",
    "migrate:pg": "prisma migrate deploy --schema prisma/schema.postgres.prisma",
    "test": "vitest run",
    "test:e2e": "vitest run test/app.e2e-spec.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.2.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "decimal.js": "^10.6.0",
    "helmet": "^8.2.0",
    "nestjs-pino": "^4.1.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.2.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.1",
    "vitest": "^2.1.8"
  }
}
