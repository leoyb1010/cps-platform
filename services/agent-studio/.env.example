# Required on server
OPENAI_API_KEY=
BROWSER_AGENT_RUNTIME=codex-app-local

# Creative text planner (OpenAI-compatible)
CREATIVE_TEXT_BASE_URL=https://api.deepseek.com
CREATIVE_TEXT_API_KEY=
CREATIVE_TEXT_MODEL=deepseek-v4-flash
CREATIVE_TEXT_FALLBACK_MODEL=deepseek-v4-pro
CREATIVE_TEXT_TIMEOUT_MS=12000

# Research / crawling providers
TREND_SOURCE_API=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
JINA_API_KEY=

# Analytics
# Server-side PostHog read needs a key (POSTHOG_API_KEY or VITE_POSTHOG_KEY) AND POSTHOG_PROJECT_ID.
ANALYTICS_API=
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://app.posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Data stores
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEON_REST_URL=

# Asset providers
IMAGE_GENERATION_API=
VIDEO_RENDER_API=

# Native Playwright executor (headless, no login). Default off — use Codex + logged-in browser.
NATIVE_PLAYWRIGHT_ENABLED=false

# Template registry (optional upstream scan roots, comma-separated)
# TEMPLATE_REGISTRY_ROOTS=/path/to/open-design,/path/to/html-anything
TEMPLATE_PICK_MODE=recommend
TEMPLATE_EXCLUDE_AGPL=true

# Local BFF (matches README and code defaults)
PORT=48787
FRONTEND_PORT=45173
