{
  "name": "agent-studio",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "server:dev": "node --env-file-if-exists=.env server/src/index.js",
    "dev:full": "concurrently \"node --env-file-if-exists=.env server/src/index.js\" \"vite --host 127.0.0.1\"",
    "local:start": "node --env-file-if-exists=.env server/src/index.js",
    "codex:poll": "node --env-file-if-exists=.env scripts/codex-poll.js",
    "executor": "node --env-file-if-exists=.env scripts/playwright-executor.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port ${FRONTEND_PORT:-45173}",
    "test": "vitest run",
    "registry:validate": "node scripts/sync-template-registry.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@hono/node-server": "^1.13.8",
    "@hyperframes/core": "0.6.73",
    "@hyperframes/producer": "0.6.73",
    "@vitejs/plugin-react": "^5.0.0",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^9.1.0",
    "hono": "^4.6.16",
    "lucide-react": "^0.468.0",
    "playwright": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "vitest": "^4.1.7"
  }
}
